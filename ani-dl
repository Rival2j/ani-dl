#!/bin/bash
cat <<"EOF"
            _            ____
 ___ ____  (_) ____  ___/ / /
/ _ `/ _ \/ / /___/ / _  / / 
\_,_/_//_/_/        \_,_/_/  
                             

EOF

# Ruta del archivo del historial
historial="$HOME/bash/.anime_historial"
anime=""
capitulo=""

# Cargar historial
if [[ -f "$historial" && -s "$historial" ]]; then
  echo "=== Historial ==="
  mapfile -t entradas < "$historial" # Lee lineas en arry

  for i in "${!entradas[@]}"; do
  	IFS':' read -r nombre cap <<< "${entradas[$i]}"
	echo "$((i+1))) $nombre (cap.$cap)"
  done
  echo " $((${entradas[@]}+1))) Ver otro anime"
  echo ""
  echo -n "Selecciona una opcion: "
  read selection

  if [["$selection" -ge 1 && "$selection" -le "${#entradas[@]}" ]] then
    # Usuario eligió un anime del historial
        IFS=':' read -r anime capitulo <<< "${entradas[$((seleccion-1))]}"
        siguiente=$((capitulo + 1))
        echo "Último capítulo visto de '$anime': $capitulo"
        echo -n "¿Ver capítulo $siguiente? (S/N): "
        read resp
        if [[ "$resp" == "S" || "$resp" == "s" ]]; then
            capitulo=$siguiente
        else
            echo -n "Número de capítulo: "
            read capitulo
        fi
    else
        # Ver otro anime nuevo
        echo -n "Nombre del anime (usa '-' para espacios): "
        read anime
        echo -n "Número de capítulo: "
        read capitulo
    fi
else
    # Sin historial
    echo -n "Nombre del anime (usa '-' para espacios): "
    read anime
    echo -n "Número de capítulo: "
    read capitulo
fi

echo -n "¿Descargar? (S/N): "
read descarga

# ---------- Guardar/actualizar historial ----------
nueva_entrada="$anime:$capitulo"

if [[ -f "$historial" ]]; then
    # Si el anime ya existe, actualizar su línea; si no, agregar
    if grep -q "^$anime:" "$historial"; then
        sed -i "s|^$anime:.*|$nueva_entrada|" "$historial"
    else
        echo "$nueva_entrada" >> "$historial"
    fi
else
    mkdir -p "$(dirname "$historial")"
    echo "$nueva_entrada" > "$historial"
fi

# Descarga de la pagina web completa (se guarda en /tmp)
envio="https://jkanime.net/$anime/$capitulo/"
wget --user-agent="Mozilla" -p $envio -P /tmp -4

# Obtener la url del video
url="$(grep -A 1 video /tmp/jkanime.net/jkplayer/um?* | grep url | cut -d"'" -f2 | head -n1)"
echo "Url: $url"

if [[ $descarga == "s" || $descarga == "S" ]]; then
  # Descargar
	yt-dlp -o "$anime-$capitulo.mp4" --downloader aria2c "$url" -P ~/Videos/$anime
else     	
  # Reproducir la url obtenida
	mpv "$url"
fi

# Eliminar carpeta de descarga
rm -rf /tmp/jkanime.net
